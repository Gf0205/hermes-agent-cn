# ==============================================================================
# .env.example - 环境变量模板
# 复制为 .env 并填入真实值，.env 已被 .gitignore 忽略
# ==============================================================================

# ====== 必需配置 ======

# 阿里云百炼 API Key
# 获取地址：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-REPLACE_ME

# Dashscope OpenAI兼容接口地址
# 国内用户使用北京区域：https://dashscope.aliyuncs.com/compatible-mode/v1
# 国际用户使用新加坡区域：https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ====== 模型配置 ======

# 主力模型（复杂任务：规划、反思）
AGENT_MODEL_STRONG=qwen3-32b

# 快速模型（简单任务：工具调用、格式化）
AGENT_MODEL_FAST=qwen3-8b

# Embedding模型（向量化）
AGENT_EMBEDDING_MODEL=text-embedding-v4
AGENT_EMBEDDING_DIM=1024

# ====== 可选配置 ======

# GitHub Token（可选，用于github相关工具）
#GITHUB_TOKEN=ghp_your-token-here

# ====== Agent行为配置 ======

# 最大迭代轮次（防止无限循环）
AGENT_MAX_ITERATIONS=30

# 是否保存执行轨迹（用于调试和回放）
AGENT_SAVE_TRACES=true
# 向量数据库配置（新增这两行）
AGENT_CHROMA_DIR=~/.hermes-cn/chroma_db   # ChromaDB持久化目录
AGENT_CHROMA_COLLECTION=hermes_memory     # 集合名称
# 日志级别：DEBUG / INFO / WARNING / ERROR
AGENT_LOG_LEVEL=INFO

# 数据存储目录（默认用户主目录下）
# AGENT_DATA_DIR=~/.hermes-cn
# ====== 新增：模型思考链配置 ======

# 是否启用思考链（仅 qwen3 系列支持）
# false = 关闭（默认，兼容性最好，适合工具调用）
# true  = 开启（输出包含 <think> 推理过程，消耗更多 Token）
AGENT_ENABLE_THINKING=false

# ====== 常见模型配置参考 ======
#
# 方案A：稳定兼容（推荐新手）
# AGENT_MODEL_STRONG=qwen-max
# AGENT_MODEL_FAST=qwen-plus
#
# 方案B：新模型体验（需要注意 enable_thinking 参数）
# AGENT_MODEL_STRONG=qwen3-32b
# AGENT_MODEL_FAST=qwen3-8b
# AGENT_ENABLE_THINKING=false
#
# 方案C：极致性价比
# AGENT_MODEL_STRONG=qwen-plus
# AGENT_MODEL_FAST=qwen-turbo